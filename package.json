{
  "name": "nova",
  "version": "0.0.0",
  "private": true,
  "description": "Nova — an original commerce & point-of-sale suite (Retail, Restaurant, eCom).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "playwright": "^1.61.1",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  }
}
